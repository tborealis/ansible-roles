---
profile: production
use_default_rules: true
rulesdir:
  - .config/ansible-lint-rules
skip_list:
  - experimental
kinds:
  # Shared molecule scenario values, not playbooks (see docs/testing.md)
  - vars: "**/molecule/*/vars.yml"
exclude_paths:
  # Agent worktrees and session tooling, not part of the collection
  - .claude
